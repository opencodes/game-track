rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Auth UID)
    // Fields:
    //   - username: string (required)
    //   - avatar: string (required)
    //   - level: int (required)
    //   - xp: int (required)
    //   - nextLevelXp: int (required)
    //   - age: int (optional)
    //   - favoriteGame: string (optional)
    //
    // Collection: games
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - duration: int (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - xpEarned: int (required)
    //   - levelAchieved: int (optional)
    //   - remark: string (optional)
    //   - userId: string (required, matches Auth UID)
    //
    // Collection: achievements
    // Document ID: auto-generated
    // Fields:
    //   - achievementId: string (required)
    //   - name: string (required)
    //   - description: string (optional)
    //   - icon: string (optional)
    //   - unlocked: bool (required)
    //   - date: string (optional, YYYY-MM-DD)
    //   - userId: string (required, matches Auth UID)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "rupa.jha.in@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}.*");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['username', 'avatar', 'level', 'xp', 'nextLevelXp', 'age', 'favoriteGame', 'role']) &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.avatar is string && data.avatar.size() > 0 &&
             data.level is int && data.level >= 0 &&
             data.xp is int && data.xp >= 0 &&
             data.nextLevelXp is int && data.nextLevelXp > 0;
    }

    function isValidGame(data) {
      return hasOnlyAllowedFields(['name', 'duration', 'date', 'xpEarned', 'levelAchieved', 'remark', 'userId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.duration is int && data.duration > 0 &&
             isValidDateString(data.date) &&
             data.xpEarned is int && data.xpEarned >= 0 &&
             data.userId == request.auth.uid;
    }

    function isValidAchievement(data) {
      return hasOnlyAllowedFields(['achievementId', 'name', 'description', 'icon', 'unlocked', 'date', 'userId']) &&
             data.achievementId is string &&
             data.name is string &&
             data.unlocked is bool &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /games/{gameId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidGame(request.resource.data);
      allow update: if isDocOwner() && isValidGame(request.resource.data) && isAdmin(); // Only admins can update logs for now
      allow delete: if isDocOwner() || isAdmin();
    }

    match /achievements/{achievementId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidAchievement(request.resource.data);
      allow update: if isDocOwner() && isValidAchievement(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
